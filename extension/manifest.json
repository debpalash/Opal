{
  "manifest_version": 3,
  "name": "Opal Connector",
  "version": "0.2.0",
  "description": "Send any website's media, articles, downloads and scraped page data to a locally-running Opal — and turn manga/novel sites into Opal sources in one click.",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Opal panel"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "sidebar_action": {
    "default_panel": "src/sidepanel/index.html",
    "default_title": "Opal",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "opal-connector@opal.app",
      "strict_min_version": "115.0"
    }
  }
}
