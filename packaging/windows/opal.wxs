<?xml version="1.0" encoding="UTF-8"?>
<!--
  Opal - WiX 3 authoring for the Windows MSI.

  This file owns the product skeleton only (upgrade identity, install
  location, Start Menu shortcut, ARP metadata). The actual payload - opal.exe,
  the torrent wrapper DLL, and the harvested MSYS2 runtime DLLs - is generated
  at build time by heat.exe from the CI staging directory into a
  ComponentGroup named "OpalFiles" (see .github/workflows/release.yml and
  packaging/windows/README.md).

  Compile-time variables (pass with candle -d...):
    ProductVersion  numeric x.y.z from the release tag (e.g. 0.3.1)
    IconPath        path to packaging/windows/opal.ico

  Compile with `candle -arch x64` so every component defaults to Win64 and
  ProgramFiles64Folder resolves to the 64-bit Program Files.

  UpgradeCode is FIXED for the lifetime of the product - never regenerate it,
  or upgrades will stop replacing older installs and users end up with two
  Opals side by side.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Opal"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="Palash Deb"
           UpgradeCode="0C799FF1-BA01-4B13-A888-A7D036460135">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Opal - play everything. The evolved media player."
             Comments="https://github.com/debpalash/Opal" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Opal is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="OpalIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="OpalIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/debpalash/Opal" />
    <Property Id="ARPHELPLINK" Value="https://github.com/debpalash/Opal/issues" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <!-- Per-machine, 64-bit: C:\Program Files\Opal -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Opal" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="OpalMenuFolder" Name="Opal" />
      </Directory>
    </Directory>

    <DirectoryRef Id="OpalMenuFolder">
      <!--
        Non-advertised Start Menu shortcut. The target file lives in the
        heat-generated fragment (its component GUIDs churn per build), so we
        point at [INSTALLFOLDER]opal.exe by path instead of a File reference
        and give this component its own registry KeyPath - the standard
        ICE-clean pattern for shortcuts to harvested files. HKMU resolves to
        HKLM under this per-machine install.
      -->
      <Component Id="StartMenuShortcut" Guid="06F45DA9-313D-4DFE-B4FA-2FF69C917817">
        <Shortcut Id="OpalStartMenuShortcut"
                  Name="Opal"
                  Description="Play everything - the evolved media player"
                  Target="[INSTALLFOLDER]opal.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="OpalIcon" />
        <RemoveFolder Id="RemoveOpalMenuFolder" On="uninstall" />
        <RegistryValue Root="HKMU" Key="Software\Opal"
                       Name="StartMenuShortcut" Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="INSTALLFOLDER">
      <!--
        File associations, registered the Default Programs way (HKLM
        RegisteredApplications + Capabilities\FileAssociations): Opal appears
        in "Open with" / Settings > Default apps for every extension below but
        does NOT hijack any existing default - the user (or SetUserFTA) picks
        it. One shared ProgId; the exe path is written as a string because the
        payload files are heat-harvested (no stable File/@Id to reference).
      -->
      <Component Id="FileAssociations" Guid="E3926C61-52C9-4486-BFCB-41CC8508164C">
        <RegistryValue Root="HKLM" Key="Software\RegisteredApplications"
                       Name="Opal" Type="string"
                       Value="Software\Opal\Capabilities" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities"
                       Name="ApplicationName" Type="string" Value="Opal" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities"
                       Name="ApplicationDescription" Type="string"
                       Value="Opal - play everything. The evolved media player." />

        <!-- Shared ProgId with the open verb. -->
        <RegistryValue Root="HKLM" Key="Software\Classes\Opal.MediaFile"
                       Type="string" Value="Opal Media File" />
        <RegistryValue Root="HKLM" Key="Software\Classes\Opal.MediaFile\DefaultIcon"
                       Type="string" Value="&quot;[INSTALLFOLDER]opal.exe&quot;,0" />
        <RegistryValue Root="HKLM" Key="Software\Classes\Opal.MediaFile\shell\open\command"
                       Type="string" Value="&quot;[INSTALLFOLDER]opal.exe&quot; &quot;%1&quot;" />

        <!-- Capabilities map + per-extension OpenWithProgids (Open with menu). -->
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".mkv" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".mp4" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".m4v" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".avi" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".mov" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".webm" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".ts" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".mp3" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".flac" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".m4a" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".opus" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".ogg" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".wav" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".mka" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".m3u" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".m3u8" Type="string" Value="Opal.MediaFile" />
        <RegistryValue Root="HKLM" Key="Software\Opal\Capabilities\FileAssociations" Name=".torrent" Type="string" Value="Opal.MediaFile" />

        <RegistryValue Root="HKLM" Key="Software\Classes\.mkv\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.mp4\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.m4v\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.avi\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.mov\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.webm\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.ts\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.mp3\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.flac\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.m4a\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.opus\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.ogg\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.wav\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.mka\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.m3u\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.m3u8\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
        <RegistryValue Root="HKLM" Key="Software\Classes\.torrent\OpenWithProgids" Name="Opal.MediaFile" Type="string" Value="" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="Opal" Level="1" AllowAdvertise="no">
      <!-- OpalFiles is emitted by heat.exe at build time. -->
      <ComponentGroupRef Id="OpalFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="FileAssociations" />
    </Feature>
  </Product>
</Wix>
